{
    "title": "Financial Analyst Agent System",
    "uid": "financial-analyst-agent-system",
    "tags": ["financial-analyst-agent-system"],
    "timezone": "browser",
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Agent Runs (24h)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(increase(financial_analyst_agent_system_agetn_runs_total[24h]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {"unit": "short"}
        }
      },
      {
        "id": 2,
        "title": "Avg Duration",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(financial_analyst_agent_system_agent_duration_seconds_bucket[1h]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {"unit": "s"}
        }
      },
      {
        "id": 3,
        "title": "Active Runs",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "financial_analyst_agent_system_agent_active_runs",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "title": "Errors (24h)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "sum(increase(financial_analyst_agent_system_errors_total[24h]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}
        }
      },
      {
        "id": 5,
        "title": "Request Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "rate(financial_analyst_agent_system_requests_total[5m])",
            "legendFormat": "{{method}} {{endpoint}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "title": "Request Latency",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(financial_analyst_agent_system_request_latency_seconds_bucket[5m]))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(financial_analyst_agent_system_request_latency_seconds_bucket[5m]))",
            "legendFormat": "p95",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {"unit": "s"}
        }
      }
    ],
    "schemaVersion": 38,
    "version": 1
  }